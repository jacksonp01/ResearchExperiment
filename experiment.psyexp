  <Flow>
    <Routine name="WelcomeScreen"/>
    <Routine name="ConditionSelection"/>
    <LoopInitiator loopType="TrialHandler" name="WithinSubjects">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="code"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="2" valType="code"/>
      <Param name="name" updates="None" val="WithinSubjects" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="VideoInstructions"/>
    <Routine name="VideoScreen"/>
    <Routine name="ScreenshotInstructions"/>
    <LoopInitiator loopType="TrialHandler" name="ScreenshotOrderTrials">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('Condition1Left', 'new1.jpg'), ('Condition1Right', 'old1.jpg'), ('Condition1Correct', 'Right'), ('Condition2Left', 'old2.jpg'), ('Condition2Right', 'new2.jpg'), ('Condition2Correct', 'Left')])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="Spreadsheets/screenshotspreadsheet.csv" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="code"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="code"/>
      <Param name="name" updates="None" val="ScreenshotOrderTrials" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="ScreenshotOrderTask"/>
    <LoopTerminator name="ScreenshotOrderTrials"/>
    <Routine name="WordListInstructions"/>
    <LoopInitiator loopType="TrialHandler" name="WordListStudyTrials">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('Condition1List', 'apple'), ('Condition2List', 'banana')]), OrderedDict([('Condition1List', 'muffin'), ('Condition2List', 'cupcake')]), OrderedDict([('Condition1List', 'orange'), ('Condition2List', 'tangerine')]), OrderedDict([('Condition1List', 'cat'), ('Condition2List', 'dog')]), OrderedDict([('Condition1List', 'pizza'), ('Condition2List', 'beer')])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="Spreadsheets/wordlistspreadsheets.csv" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="code"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="code"/>
      <Param name="name" updates="None" val="WordListStudyTrials" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="WordListStudy"/>
    <LoopTerminator name="WordListStudyTrials"/>
    <Routine name="WordListDistraction"/>
    <Routine name="WordListTest"/>
    <Routine name="BreakOrFinish"/>
    <LoopTerminator name="WithinSubjects"/>
    <Routine name="EndScreen"/>
  </Flow>
</PsychoPy2experiment>
